{#- Republished 2026-07-16 (Patrick): general lodging info for now — the inn, The
    Brunswick Inn, and other verified hotels around Harpswell and Brunswick. The
    per-guest room-block view (sign-in) can layer on later; see docs/data-lodging.md
    for the verified source data. -#}
<section class="section section--scene" style="--scene:var(--scene-harbor)">
  <div class="wrap center stack">
    <span class="label eyebrow">Where to stay</span>
    <h2>A place to rest your head</h2>
    <p class="lead">A few options near the inn, from the water's edge to nearby Brunswick.</p>
  </div>
</section>

<section class="section section--cream">
  <div class="wrap">
    <div class="grid grid--2">
      {% for s in site.stay %}
      <div class="card">
        <h3>{{ s.name }}</h3>
        <p>{{ s.note }}</p>
        {% if s.url and s.url != '#' %}<p style="margin:0"><a href="{{ s.url }}" rel="noopener">Their site &rarr;</a></p>{% endif %}
      </div>
      {% endfor %}
    </div>
    <p class="note center" style="margin-top:28px">Booking details and any room block will be confirmed here. August books up early out here, so grab a room once you know you're coming.</p>
  </div>
</section>

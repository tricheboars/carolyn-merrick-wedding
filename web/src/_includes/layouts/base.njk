<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} · {{ site.couple.short }}</title>
  <meta name="description" content="{{ description or site.tagline }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="{{ site.couple.short }}">
  <meta property="og:title" content="{{ title }} · {{ site.couple.short }} · {{ site.date.display }}">
  <meta property="og:description" content="{{ description or site.tagline }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:image" content="{{ site.url }}/assets/img/og-image.jpg">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:alt" content="Carolyn and Merrick on the coast">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="theme-color" content="#3F0013">
  <link rel="icon" href="/assets/svg/favicon.svg" type="image/svg+xml">
  <link rel="icon" href="/assets/img/favicon-32.png" type="image/png" sizes="32x32">
  <link rel="apple-touch-icon" href="/assets/img/apple-touch-icon.png">
  <link rel="manifest" href="/assets/site.webmanifest">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3/dist/tabler-icons.min.css">
  {% if page.url == '/' %}
  <link rel="preload" as="image" href="/assets/img/g01-hero-m.jpg" media="(max-width:680px)">
  <link rel="preload" as="image" href="/assets/img/gallery/g01.jpg" media="(min-width:680.1px)">
  {% endif %}
  <link rel="stylesheet" href="/assets/css/style.css?v={{ build.time }}">
  <script>window.CM_API=(['localhost','127.0.0.1'].includes(location.hostname))?'http://localhost:3000':'';</script>
  <script defer src="/assets/js/alpine.min.js?v={{ build.time }}"></script>
</head>
<body>
  <a href="#main" class="sr-only">Skip to content</a>
  {% include "partials/nav.njk" %}
  <main id="main">
    {{ content | safe }}
  </main>
  {% include "partials/footer.njk" %}
</body>
</html>

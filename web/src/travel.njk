---
layout: layouts/base.njk
title: Travel
permalink: /travel/
---
<section class="section section--scene" style="--scene:var(--scene-harbor)">
  <div class="wrap center stack">
    <span class="label eyebrow">Getting here</span>
    <h2>Getting to Harpswell</h2>
    <p class="lead">{{ site.travel.intro }}</p>
  </div>
</section>

<section class="section section--cream">
  <div class="wrap">
    <div class="grid grid--2">
      <div class="card">
        <h3>Fly</h3>
        <p><strong>{{ site.travel.airport.name }}</strong>: {{ site.travel.airport.note }}</p>
        <p class="note">Alternate: {{ site.travel.alt.name }}, {{ site.travel.alt.note }}</p>
      </div>
      <div class="card">
        <h3>To &amp; from the airport</h3>
        <p>{{ site.travel.transfers.toInn }}</p>
        <p>{{ site.travel.transfers.toAirport }}</p>
        <p style="margin:0"><a class="btn btn--ink" href="tel:{{ site.travel.transfers.taxiPhone | replace('(','') | replace(')','') | replace(' ','') | replace('-','') }}">Call {{ site.travel.transfers.taxiName }} {{ site.travel.transfers.taxiPhone }}</a></p>
      </div>
      <div class="card">
        <h3>Drive</h3>
        <p>{{ site.travel.drive }}</p>
        <p class="note">Parking: {{ site.travel.parking }}</p>
      </div>
      <div class="card">
        <h3>The venue</h3>
        <p>{{ site.venue.name }}<br>{{ site.venue.address }}</p>
        <p><a class="btn btn--ink" href="https://www.google.com/maps/search/?api=1&query={{ site.venue.mapsQuery }}">Open in Maps →</a></p>
      </div>
    </div>

    <div class="card" style="margin-top:24px">
      <h3>Shuttle schedule</h3>
      <p style="margin:0">{{ site.travel.shuttle }}</p>
    </div>

    <div class="divider" style="margin-top:34px"><img src="/assets/svg/poppy-divider.svg" alt="" width="110" height="59"></div>

    <div class="center stack" style="margin-bottom:8px">
      <h2>Getting around</h2>
      <p class="lead" style="max-width:720px; margin-left:auto; margin-right:auto">{{ site.gettingAround.intro }}</p>
    </div>
    <div class="grid grid--3">
      {% for o in site.gettingAround.options %}
      <div class="card">
        <h3>{{ o.name }}</h3>
        <p>{{ o.note }}</p>
        {% if o.phone %}<p style="margin:0 0 8px"><a class="btn btn--ink" href="tel:{{ o.phone | replace('(','') | replace(')','') | replace(' ','') | replace('-','') }}">Call {{ o.phone }}</a></p>{% endif %}
        <p style="margin:0"><a href="{{ o.url }}">More info &rarr;</a></p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section section--olive">
  <div class="wrap stack">
    <div class="center stack" style="margin-bottom:8px">
      <span class="label eyebrow">While you're here</span>
      <h2>Things to do around Harpswell</h2>
    </div>
    <div class="grid grid--2">
      {% for t in site.thingsToDo %}
      <div class="card card--olive">
        <h3>{{ t.name }}</h3>
        <p style="margin:0{% if t.url %} 0 8px{% endif %}">{{ t.note }}</p>
        {% if t.url %}<p style="margin:0"><a href="{{ t.url }}">More &rarr;</a></p>{% endif %}
      </div>
      {% endfor %}
    </div>
  </div>
</section>

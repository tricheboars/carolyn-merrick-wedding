---
layout: layouts/base.njk
title: RSVP
permalink: /rsvp/
---
<section class="section section--olive">
  <div class="wrap center stack">
    <span class="label eyebrow">Kindly reply</span>
    <h2>RSVP</h2>
    <p class="lead">By {{ site.rsvp.deadline }}. {{ site.rsvp.note }}</p>
  </div>
</section>

<section class="section section--cream">
  <div class="wrap" style="max-width:620px">
    <form class="form" onsubmit="return false" @submit.prevent="submit($event)" x-data="{ attending:'', party:1, sent:false, error:'', busy:false,
      async submit(e){ this.busy=true; this.error='';
        const fd=Object.fromEntries(new FormData(e.target).entries());
        try{ const r=await fetch((window.CM_API||'')+'/api/rsvp',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(fd)});
          if(r.ok){ this.sent=true; this.$nextTick(()=>e.target.scrollIntoView({behavior:'smooth',block:'center'})); }
          else{ this.error='form'; } }
        catch(_){ this.error='network'; }
        finally{ this.busy=false; } } }">
      <div x-show="!sent">
        <div class="field">
          <label for="name">Full name(s)</label>
          <input id="name" name="name" type="text" placeholder="Jane &amp; John Smith" autocomplete="name" required>
        </div>

        <div class="field">
          <label for="contact">Email or mobile</label>
          <input id="contact" name="contact" type="text" placeholder="So we can send updates" autocomplete="email" autocapitalize="none" autocorrect="off" spellcheck="false" required>
        </div>

        <div class="field">
          <label>Will you join us?</label>
          <label class="choice"><input type="radio" name="attending" value="yes" x-model="attending" required> Joyfully accepts</label>
          <label class="choice"><input type="radio" name="attending" value="no" x-model="attending" required> Regretfully declines</label>
        </div>

        <template x-if="attending === 'yes'">
          <div>
            <div class="field">
              <label for="party">Number in your party</label>
              <input id="party" name="party" type="number" min="1" max="10" x-model="party">
            </div>
            <div class="field">
              <label for="meal">Meal preference</label>
              <select id="meal" name="meal">
                <option value="">Select…</option>
                <option>Catch of the day</option>
                <option>Farm vegetable</option>
                <option>Chicken</option>
              </select>
            </div>
            <div class="field">
              <label for="diet">Dietary needs / allergies</label>
              <input id="diet" name="diet" type="text" placeholder="Optional">
            </div>
            <div class="field">
              <label for="song">A song to get you dancing</label>
              <input id="song" name="song" type="text" placeholder="Optional">
            </div>
          </div>
        </template>

        <div class="field">
          <label for="msg">A note for the couple</label>
          <textarea id="msg" name="message" rows="3" placeholder="Optional"></textarea>
        </div>

        <p x-show="error" x-cloak class="note" style="color:var(--brick)" x-text="error === 'form' ? 'Something in the form needs another look. Please check your answers and send it again.' : 'We couldn\'t reach the server just now. Please try again in a minute.'"></p>
        <button class="btn btn--ink" type="submit" x-bind:disabled="busy" x-text="busy ? 'Sending…' : 'Send RSVP'">Send RSVP</button>
        <p class="note" style="margin-top:14px">Your reply goes straight to the couple's guest list.</p>
      </div>

      <div x-show="sent" x-cloak class="center stack">
        <div class="divider"><img src="/assets/svg/coupes.svg" alt="" width="78" height="54"></div>
        <h3 x-text="attending === 'no' ? 'We\'ll miss you!' : 'Thank you! We can\'t wait to see you.'"></h3>
        <p class="note">Your RSVP is saved on the couple's guest list. Need to change anything later? Just send the form again with your update.</p>
      </div>
    </form>
  </div>
</section>
